@inject Microsoft.JSInterop.IJSRuntime JS
@inject FSI.BusinessProcessManagement.Services.Http.TokenAccessor Tokens

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var token = await JS.InvokeAsync<string>("appAuth.getToken", Array.Empty<object>());
        if (!string.IsNullOrWhiteSpace(token))
            await Tokens.SetTokenAsync(token); // grava no cache e no localStorage
    }
}
