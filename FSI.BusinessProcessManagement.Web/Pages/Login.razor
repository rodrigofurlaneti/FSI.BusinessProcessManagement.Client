@page "/login"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using FSI.BusinessProcessManagement.Services

@attribute [AllowAnonymous]
@inject AuthService Auth
@inject NavigationManager Nav

@* Se quiser que a tela de login não use o MainLayout, deixe sem @layout (ou use um layout minimal) *@
@* @layout null *@

<div class="auth-center">
    <div class="card w-100" style="max-width:520px">
        <div class="card-body">
            <h1 class="h3 mb-4 text-center">Login</h1>

            <EditForm Model="_vm" OnValidSubmit="DoLogin">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Usuário</label>
                    <InputText class="form-control" @bind-Value="_vm.Username" autofocus />
                </div>

                <div class="mb-3">
                    <label class="form-label">Senha</label>
                    <InputText class="form-control" @bind-Value="_vm.Password" type="password" />
                </div>

                <button class="btn btn-primary w-100" disabled="@_loading">
                    @(_loading ? "Entrando..." : "Entrar")
                </button>

                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <div class="alert alert-danger mt-3">@_error</div>
                }
            </EditForm>
        </div>
    </div>
</div>

@code {
    // Captura ?returnUrl=/alvo após redirecionamento
    [SupplyParameterFromQuery] public string? returnUrl { get; set; }

    private record LoginVm
    {
        [Required] public string Username { get; set; } = string.Empty;
        [Required] public string Password { get; set; } = string.Empty;
    }

    private LoginVm _vm = new();
    private bool _loading;
    private string? _error;

    private async Task DoLogin()
    {
        if (_loading) return;
        _loading = true;
        _error = null;

        try
        {
            var ok = await Auth.LoginAsync(_vm.Username, _vm.Password);

            if (ok)
            {
                var target = string.IsNullOrWhiteSpace(returnUrl) ? "/" : returnUrl!;
                Nav.NavigateTo(target, replace: true);
                return;
            }

            _error = "Usuário ou senha inválidos.";
        }
        catch (Exception ex)
        {
            _error = "Falha ao autenticar. " + ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
