@page "/roles"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using FSI.BusinessProcessManagement.Models.Dto
@using FSI.BusinessProcessManagement.Models.ViewModel
@attribute [Authorize(Roles = "Administrador")]
@inject FSI.BusinessProcessManagement.Services.RoleService Roles
@inject FSI.BusinessProcessManagement.Services.Http.TokenAccessor Tokens

<Microsoft.AspNetCore.Components.Web.PageTitle>Perfis</Microsoft.AspNetCore.Components.Web.PageTitle>

<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2 mb-3">
    <h2 class="m-0">Perfis</h2>

    <div class="d-flex gap-2 w-100 w-md-auto">
        <InputText class="form-control"
                   Value=""
                   ValueChanged="OnFilterChanged"
                   ValueExpression="() => Filter" />

        <InputSelect class="form-select" style="max-width:140px" @bind-Value="PageSize" TValue="int">
            <option value="5">5 / pág</option>
            <option value="10">10 / pág</option>
            <option value="20">20 / pág</option>
            <option value="50">50 / pág</option>
        </InputSelect>

        <a id="OpenCreate" name="OpenCreate" class="btn btn-primary" href="/roles/create">
            Novo
        </a>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-sm align-middle">
        <thead class="table-dark">
            <tr>
                <th>Perfil</th>
                <th>Descrição</th>
                <th style="width:170px;"></th>
            </tr>
        </thead>
        <tbody>
            @if (loading)
            {
                <tr><td colspan="5" class="text-center py-4">Carregando...</td></tr>
            }
            else if (paged.Count == 0)
            {
                <tr><td colspan="5" class="text-center py-4">Nenhum perfil encontrado.</td></tr>
            }
            else
            {
                @foreach (var u in paged)
                {
                    <tr>
                        <td class="text-nowrap">@u.RoleName</td>
                        <td class="text-break">@u.Description</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a class="btn btn-outline-secondary"
                                   href="@($"/roles/edit/{u.RoleId}")">
                                    Editar
                                </a>
                                <a class="btn btn-outline-danger"
                                   href="@($"/roles/delete/{u.RoleId}")">
                                    Excluir
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@if (totalPages > 1)
{
    <nav class="d-flex justify-content-between align-items-center my-3">
        <div class="small text-muted">
            Página @(page) de @(totalPages) — Total: @(filtered.Count)
        </div>
        <ul class="pagination m-0">
            <li class="page-item @(page == 1 ? "disabled" : "")">
                <button class="page-link" @onclick="() => Go(page - 1)">Anterior</button>
            </li>
            @for (var i = Math.Max(1, page - 2); i <= Math.Min(totalPages, page + 2); i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <button class="page-link" @onclick="() => Go(i)">@i</button>
                </li>
            }
            <li class="page-item @(page == totalPages ? "disabled" : "")">
                <button class="page-link" @onclick="() => Go(page + 1)">Próxima</button>
            </li>
        </ul>
    </nav>
}

@if (showDelete && deletingRole is not null)
{
    <div class="modal fade show" style="display:block;" tabindex="-1" aria-modal="true" role="dialog">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Excluir perfil</h5>
                    <button type="button" class="btn-close" @onclick="CloseDelete"></button>
                </div>

                <div class="modal-body">
                    Tem certeza que deseja excluir <strong>@deletingRole.RoleName</strong>?
                </div>

                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" @onclick="CloseDelete">Cancelar</button>
                    <button class="btn btn-danger" @onclick="DeleteAsync" disabled="@deleting">
                        @(deleting ? "Excluindo..." : "Excluir")
                    </button>
                </div>

            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">@_error</div>
}

@code {
    private bool loading;
    private List<RoleDto> all = new();
    private List<RoleDto> filtered = new();
    private List<RoleDto> paged = new();
    private int page = 1, totalPages = 1;
    private bool showEdit, saving;
    private bool showDelete, deleting;
    private RoleDto? deletingRole;
    private RoleEditVm vm = new();
    private string? _error;

    // filtro + debounce
    private string? filter;
    private System.Timers.Timer? filterTimer;

    // page size controlado por propriedade
    private int _pageSize = 10;
    private int PageSize
    {
        get => _pageSize;
        set
        {
            if (_pageSize == value) return;
            _pageSize = value;
            ApplyFilterAndPaging(1);
        }
    }

    private void OnFilterChanged(string? value)
    {
        Filter = value;
        // seu debounce aqui...
        filterTimer?.Stop();
        if (filterTimer is null)
        {
            filterTimer = new System.Timers.Timer(300) { AutoReset = false };
            filterTimer.Elapsed += (_, __) => InvokeAsync(() =>
            {
                ApplyFilterAndPaging(1);
                StateHasChanged();
            });
        }
        filterTimer.Start();
    }

    private string? Filter
    {
        get => filter;
        set
        {
            filter = value;
            filterTimer?.Stop();
            if (filterTimer is null)
            {
                filterTimer = new System.Timers.Timer(300) { AutoReset = false };
                filterTimer.Elapsed += (_, __) =>
                  InvokeAsync(() => { ApplyFilterAndPaging(1); StateHasChanged(); });
            }
            filterTimer.Start();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await Tokens.WaitForTokenAsync(TimeSpan.FromSeconds(3));

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            loading = true;
            _error = null;
            all = await Roles.GetAllAsync() ?? new();
        }
        catch (Exception ex)
        {
            _error = "Falha ao carregar perfis: " + ex.Message;
            all = new();
        }
        finally
        {
            loading = false;
            ApplyFilterAndPaging(1);
            StateHasChanged();
        }
    }

    private void ApplyFilterAndPaging(int newPage)
    {
        page = newPage;

        var f = (filter ?? "").Trim().ToLowerInvariant();
        filtered = string.IsNullOrEmpty(f)
          ? all
          : all.Where(u =>
                (u.RoleName ?? string.Empty).ToLowerInvariant().Contains(f)
             || (u.Description ?? string.Empty).ToLowerInvariant().Contains(f))
               .ToList();

        totalPages = Math.Max(1, (int)Math.Ceiling(filtered.Count / (double)_pageSize));
        page = Math.Min(Math.Max(1, page), totalPages);

        paged = filtered
          .Skip((page - 1) * _pageSize)
          .Take(_pageSize)
          .ToList();
    }

    private void Go(int p) => ApplyFilterAndPaging(p);

    private void OpenCreate()
    {
        vm = new RoleEditVm { };
        showEdit = true;
    }

    private void OpenEdit(RoleDto u)
    {
        vm = new RoleEditVm
        {
            RoleId = u.RoleId,
            RoleName = u.RoleName,
            Description = u.Description
        };
        showEdit = true;
    }

    private void CloseEdit() => showEdit = false;

    private void OpenDelete(RoleDto u)
    {
        deletingRole = u;
        showDelete = true;
    }

    private void CloseDelete()
    {
        showDelete = false;
        deletingRole = null;
    }

    private async Task DeleteAsync()
    {
        if (deletingRole is null) return;
        deleting = true;
        await Roles.DeleteAsync(deletingRole.RoleId);
        deleting = false;
        showDelete = false;

        all.RemoveAll(x => x.RoleId == deletingRole.RoleId);
        ApplyFilterAndPaging(page);
    }
}
