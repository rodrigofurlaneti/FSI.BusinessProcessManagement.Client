@page "/users/create"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using FSI.BusinessProcessManagement.Models.ViewModel
@attribute [Authorize(Roles = "Administrador")]
@inject FSI.BusinessProcessManagement.Services.UserService Users
@inject FSI.BusinessProcessManagement.Services.Http.TokenAccessor Tokens
@inject NavigationManager Nav

<Microsoft.AspNetCore.Components.Web.PageTitle>Novo usuário</Microsoft.AspNetCore.Components.Web.PageTitle>

<h2 class="mb-3">Novo usuário</h2>

<EditForm Model="vm" OnValidSubmit="SaveAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">Usuário</label>
            <InputText class="form-control" @bind-Value="vm.Username" />
            <ValidationMessage For="() => vm.Username" />
        </div>

        <div class="col-md-8">
            <label class="form-label">Email</label>
            <InputText class="form-control" @bind-Value="vm.Email" />
            <ValidationMessage For="() => vm.Email" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Departamento (opcional)</label>
            <InputNumber class="form-control" @bind-Value="vm.DepartmentId" />
            <div class="form-text">Informe o ID do departamento (se aplicável).</div>
        </div>

        <div class="col-md-6">
            <label class="form-label">Senha inicial</label>
            <InputText class="form-control" type="password" @bind-Value="vm.PasswordHash" />
            <ValidationMessage For="() => vm.PasswordHash" />
        </div>

        <div class="col-12">
            <div class="form-check">
                <InputCheckbox class="form-check-input" @bind-Value="vm.IsActive" />
                <label class="form-check-label">Ativo</label>
            </div>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <button class="btn btn-primary" disabled="@saving">@(saving ? "Salvando..." : "Salvar")</button>
        <button type="button" class="btn btn-outline-secondary" @onclick="Cancel">Cancelar</button>
    </div>
</EditForm>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger mt-3">@_error</div>
}

@code {
    private UserCreateVm vm = new() { IsActive = true };
    private bool saving;
    private string? _error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Tokens.WaitForTokenAsync(TimeSpan.FromSeconds(3));
        StateHasChanged();
    }

    private async Task SaveAsync()
    {
        try
        {
            saving = true;
            await Users.CreateAsync(vm);
            Nav.NavigateTo("/users");
        }
        catch (Exception ex)
        {
            _error = "Falha ao salvar: " + ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private void Cancel() => Nav.NavigateTo("/users");
}
