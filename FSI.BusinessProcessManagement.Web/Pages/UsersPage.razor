@page "/users"
@using System.ComponentModel.DataAnnotations
@using FSI.BusinessProcessManagement.Models.Dto
@using FSI.BusinessProcessManagement.Models.ViewModel
@attribute [Authorize(Roles = "Administrador")]
@inject FSI.BusinessProcessManagement.Services.UserService Users
@inject FSI.BusinessProcessManagement.Services.Http.TokenAccessor Tokens

<Microsoft.AspNetCore.Components.Web.PageTitle>Usuários</Microsoft.AspNetCore.Components.Web.PageTitle>

<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2 mb-3">
  <h2 class="m-0">Usuários</h2>

  <div class="d-flex gap-2 w-100 w-md-auto">
        <InputText class="form-control"
                   placeholder="Filtrar por usuário ou e-mail..."
                   @bind-Value="Filter" @bind-Value:event="oninput" />

        <InputSelect class="form-select" style="max-width:140px" @bind-Value="PageSize">
            <option value="5">5 / pág</option>
            <option value="10">10 / pág</option>
            <option value="20">20 / pág</option>
            <option value="50">50 / pág</option>
        </InputSelect>

    <button class="btn btn-primary" @onclick="OpenCreate">
      Novo
    </button>
  </div>
</div>

<div class="table-responsive">
  <table class="table table-sm align-middle">
    <thead class="table-dark">
      <tr>
        <th style="width:80px;">ID</th>
        <th>Usuário</th>
        <th>Email</th>
        <th style="width:120px;">Ativo</th>
        <th style="width:170px;"></th>
      </tr>
    </thead>
    <tbody>
      @if (loading)
      {
        <tr><td colspan="5" class="text-center py-4">Carregando...</td></tr>
      }
      else if (paged.Count == 0)
      {
        <tr><td colspan="5" class="text-center py-4">Nenhum usuário encontrado.</td></tr>
      }
      else
      {
        @foreach (var u in paged)
        {
          <tr>
            <td>@u.Id</td>
            <td class="text-nowrap">@u.Username</td>
            <td class="text-break">@u.Email</td>
            <td>
              <span class="badge @(u.IsActive ? "text-bg-success" : "text-bg-secondary")">
                @(u.IsActive ? "Ativo" : "Inativo")
              </span>
            </td>
            <td class="text-end">
              <div class="btn-group btn-group-sm">
                <button class="btn btn-outline-secondary" @onclick="() => OpenEdit(u)">Editar</button>
                <button class="btn btn-outline-danger" @onclick="() => OpenDelete(u)">Excluir</button>
              </div>
            </td>
          </tr>
        }
      }
    </tbody>
  </table>
</div>

@if (totalPages > 1)
{
  <nav class="d-flex justify-content-between align-items-center my-3">
    <div class="small text-muted">
      Página @(page) de @(totalPages) — Total: @(filtered.Count)
    </div>
    <ul class="pagination m-0">
      <li class="page-item @(page == 1 ? "disabled" : "")">
        <button class="page-link" @onclick="() => Go(page - 1)">Anterior</button>
      </li>
      @for (var i = Math.Max(1, page - 2); i <= Math.Min(totalPages, page + 2); i++)
      {
        <li class="page-item @(i == page ? "active" : "")">
          <button class="page-link" @onclick="() => Go(i)">@i</button>
        </li>
      }
      <li class="page-item @(page == totalPages ? "disabled" : "")">
        <button class="page-link" @onclick="() => Go(page + 1)">Próxima</button>
      </li>
    </ul>
  </nav>
}

@if (showEdit)
{
  <div class="modal fade show" style="display:block;" tabindex="-1" aria-modal="true" role="dialog">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">

        <div class="modal-header">
          <h5 class="modal-title">@((vm.Id == 0) ? "Novo usuário" : $"Editar usuário #{vm.Id}")</h5>
          <button type="button" class="btn-close" @onclick="CloseEdit"></button>
        </div>

        <EditForm Model="vm" OnValidSubmit="SaveAsync">
          <DataAnnotationsValidator />
          <div class="modal-body">
            <div class="row g-3">
              <div class="col-md-4">
                <label class="form-label">Usuário</label>
                <InputText class="form-control" @bind-Value="vm.Username" />
                <ValidationMessage For="() => vm.Username" />
              </div>

              <div class="col-md-8">
                <label class="form-label">Email</label>
                <InputText class="form-control" @bind-Value="vm.Email" />
                <ValidationMessage For="() => vm.Email" />
              </div>

              <div class="col-md-6">
                <label class="form-label">Departamento (opcional)</label>
                <InputNumber class="form-control" @bind-Value="vm.DepartmentId" />
                <div class="form-text">Informe o ID do departamento (se aplicável).</div>
              </div>

              @if (vm.Id == 0)
              {
                <div class="col-md-6">
                  <label class="form-label">Senha inicial</label>
                  <InputText class="form-control" type="password" @bind-Value="vm.InitialPassword" />
                  <ValidationMessage For="() => vm.InitialPassword" />
                </div>
              }

              <div class="col-12">
                <div class="form-check">
                  <InputCheckbox class="form-check-input" @bind-Value="vm.IsActive" />
                  <label class="form-check-label">Ativo</label>
                </div>
              </div>
            </div>
          </div>

          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" @onclick="CloseEdit">Cancelar</button>
            <button class="btn btn-primary" disabled="@saving">@(saving ? "Salvando..." : "Salvar")</button>
          </div>
        </EditForm>

      </div>
    </div>
  </div>
  <div class="modal-backdrop fade show"></div>
}

@if (showDelete && deletingUser is not null)
{
  <div class="modal fade show" style="display:block;" tabindex="-1" aria-modal="true" role="dialog">
    <div class="modal-dialog">
      <div class="modal-content">

        <div class="modal-header">
          <h5 class="modal-title">Excluir usuário</h5>
          <button type="button" class="btn-close" @onclick="CloseDelete"></button>
        </div>

        <div class="modal-body">
          Tem certeza que deseja excluir <strong>@deletingUser.Username</strong>?
        </div>

        <div class="modal-footer">
          <button class="btn btn-outline-secondary" type="button" @onclick="CloseDelete">Cancelar</button>
          <button class="btn btn-danger" @onclick="DeleteAsync" disabled="@deleting">
            @(deleting ? "Excluindo..." : "Excluir")
          </button>
        </div>

      </div>
    </div>
  </div>
  <div class="modal-backdrop fade show"></div>
}

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">@_error</div>
}

@code {
    private bool loading;
    private List<UserDto> all = new();
    private List<UserDto> filtered = new();
    private List<UserDto> paged = new();
    private int page = 1, pageSize = 10, totalPages = 1;
    private bool showEdit, saving;
    private bool showDelete, deleting;
    private UserDto? deletingUser;
    private UserEditVm vm = new();
    private string? _error;
    private string? filter;
    private System.Timers.Timer? filterTimer;
    private int _pageSize = 10;

    private int PageSize
    {
        get => _pageSize;
        set
        {
            if (_pageSize == value) return;
            _pageSize = value;
            ApplyFilterAndPaging(1);
        }
    }

    private string? Filter
    {
        get => filter;
        set
        {
            filter = value;
            filterTimer?.Stop();
            if (filterTimer is null)
            {
                filterTimer = new System.Timers.Timer(300) { AutoReset = false };
                filterTimer.Elapsed += (_, __) =>
                    InvokeAsync(() => { ApplyFilterAndPaging(1); StateHasChanged(); });
            }
            filterTimer.Start();
        }
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        for (var i = 0; i < 20; i++)
        {
            var tk = await Tokens.GetTokenAsync();
            if (!string.IsNullOrWhiteSpace(tk)) break;
            await Task.Delay(100);
        }

        await LoadAsync();
    }

    private void OnFilterInput(ChangeEventArgs e)
    {
        filter = e.Value?.ToString();
        filterTimer?.Stop();
        filterTimer ??= new System.Timers.Timer(300) { AutoReset = false };
        filterTimer.Elapsed += (_, __) => InvokeAsync(() => { ApplyFilterAndPaging(1); StateHasChanged(); });
        filterTimer.Start();
    }

    private async Task LoadAsync()
    {
        try
        {
            loading = true;
            _error = null;
            all = await Users.GetAllAsync() ?? new();
        }
        catch (Exception ex)
        {
            _error = "Falha ao carregar usuários: " + ex.Message;
            all = new();
        }
        finally
        {
            loading = false;
            ApplyFilterAndPaging(1);
            StateHasChanged();
        }
    }

    private void HandlePageSizeChange(ChangeEventArgs e)
    {
        if (int.TryParse(e?.Value?.ToString(), out var s))
        {
            pageSize = s;
            ApplyFilterAndPaging(1);
        }
    }

    private void OnFilterChanged(ChangeEventArgs _)
    {
        filterTimer?.Stop();
        filterTimer ??= new System.Timers.Timer(300) { AutoReset = false };
        filterTimer.Elapsed += (_, __) => InvokeAsync(() => { ApplyFilterAndPaging(1); StateHasChanged(); });
        filterTimer.Start();
    }

    private void ApplyFilterAndPaging(int newPage)
    {
        page = newPage;

        var f = (filter ?? "").Trim().ToLowerInvariant();
        filtered = string.IsNullOrEmpty(f)
          ? all
          : all.Where(u =>
                (u.Username ?? string.Empty).ToLowerInvariant().Contains(f)
             || (u.Email ?? string.Empty).ToLowerInvariant().Contains(f))
               .ToList();

        totalPages = Math.Max(1, (int)Math.Ceiling(filtered.Count / (double)pageSize));
        page = Math.Min(Math.Max(1, page), totalPages);

        paged = filtered
          .Skip((page - 1) * pageSize)
          .Take(pageSize)
          .ToList();
    }

    private void Go(int p) => ApplyFilterAndPaging(p);

    private void OpenCreate()
    {
        vm = new UserEditVm { IsActive = true };
        showEdit = true;
    }

    private void OpenEdit(UserDto u)
    {
        vm = new UserEditVm
        {
            Id = u.Id,
            Username = u.Username,
            Email = u.Email,
            DepartmentId = u.DepartmentId,
            IsActive = u.IsActive
        };
        showEdit = true;
    }

    private void CloseEdit() => showEdit = false;

    private async Task SaveAsync()
    {
        saving = true;

        if (vm.Id == 0) await Users.CreateAsync(vm);
        else await Users.UpdateAsync(vm);

        saving = false;
        showEdit = false;

        await LoadAsync(); // recarrega com os dados atualizados
    }

    private void OpenDelete(UserDto u)
    {
        deletingUser = u;
        showDelete = true;
    }

    private void CloseDelete()
    {
        showDelete = false;
        deletingUser = null;
    }

    private async Task DeleteAsync()
    {
        if (deletingUser is null) return;
        deleting = true;
        await Users.DeleteAsync(deletingUser.Id);
        deleting = false;
        showDelete = false;

        all.RemoveAll(x => x.Id == deletingUser.Id);
        ApplyFilterAndPaging(page);
    }
}